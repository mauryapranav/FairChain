# ── Root .env — used by docker-compose ───────────────────────────────────────
# Copy this file to .env and fill in the values.
# See SETUP.md for where to get each key.

# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string-generate-at-generate-secret.vercel.app

# ── URLs (change for production) ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Razorpay (leave empty for mock payment mode) ──────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── IPFS / Pinata (leave empty for mock IPFS mode) ────────────────────────────
PINATA_JWT=

# ── Polygon Amoy blockchain (leave empty for mock blockchain mode) ─────────────
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
ESCROW_CONTRACT_ADDRESS=
PROOF_REGISTRY_ADDRESS=
DEPLOY_WALLET_PRIVATE_KEY=
ADMIN_WALLET=
